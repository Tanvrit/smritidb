{
  "name": "@tanvrit/smritidb",
  "version": "0.1.0",
  "description": "An open biology-inspired associative memory layer. Storage that remembers by partial cue, degrades like a hologram, and consolidates with use. TypeScript reference implementation.",
  "author": {
    "name": "Tanvrit Private Limited",
    "url": "https://tanvrit.com",
    "email": "opensource@tanvrit.com"
  },
  "license": "Apache-2.0",
  "homepage": "https://smritidb.com",
  "bugs": {
    "url": "https://github.com/Tanvrit/smritidb/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tanvrit/smritidb.git",
    "directory": "packages/core-ts"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test 'src/**/*.test.ts'",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "cp ../../LICENSE LICENSE && cp ../../NOTICE NOTICE && pnpm test && pnpm build"
  },
  "keywords": [
    "associative-memory",
    "hyperdimensional-computing",
    "sparse-distributed-memory",
    "vector-symbolic-architectures",
    "content-addressable",
    "vector-database",
    "semantic-search",
    "ai-memory",
    "smriti",
    "storage"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "dependencies": {
    "@noble/hashes": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.0"
  }
}
